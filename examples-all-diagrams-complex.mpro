      "code": "sequenceDiagram\n    actor U as User\n    participant UI as WebUI\n    participant GW as ApiGateway\n    participant OR as OrderService\n    participant IV as InventoryService\n    participant PY as PaymentService\n    participant SH as ShippingService\n    participant NT as NotificationService\n\n    U->>UI: clickCheckout()\n    UI->>GW: POST /checkout\n    GW->>OR: createOrder(cartId,userId)\n    OR->>IV: reserve(items)\n    IV-->>OR: reservationId\n    OR->>PY: authorize(amount,token)\n    PY-->>OR: authId\n    OR->>SH: createShipment(orderId,addressId)\n    SH-->>OR: shipmentId\n    OR->>NT: sendOrderConfirmed(orderId,userId)\n    NT-->>U: email and push confirmation\n    OR-->>GW: 201 orderId\n    GW-->>UI: success(orderId,eta)\n    UI-->>U: renderConfirmation()\n    OR->>PY: capture(authId)\n    PY-->>OR: captureOk\n    OR->>IV: finalizeReservation(reservationId)\n    IV-->>OR: stockCommitted"
    },
