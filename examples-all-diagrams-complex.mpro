      "autoSync": false,
      "theme": "dark",
      "code": "classDiagram\n    direction LR\n\n    class DiagramEngine {\n      -registry: PluginRegistry\n      -renderQueue: RenderQueue\n      +loadProject(path: string): Project\n      +saveProject(project: Project): bool\n      +render(project: Project): RenderResult\n      +runValidation(project: Project): ValidationReport\n    }\n\n    class PluginRegistry {\n      -plugins: Map~string,DiagramPlugin~\n      +register(plugin: DiagramPlugin): void\n      +unregister(pluginId: string): void\n      +resolve(type: string): DiagramPlugin\n      +list(): DiagramPlugin[]\n    }\n\n    class DiagramPlugin <<interface>>\n\n    class FlowchartPlugin {\n      +supports(type: string): bool\n      +parse(code: string): Graph\n      +serialize(graph: Graph): string\n    }\n\n    class SequencePlugin {\n      +supports(type: string): bool\n      +parse(code: string): Graph\n      +serialize(graph: Graph): string\n    }\n\n    class Project {\n      +title: string\n      +owner: string\n      +diagrams: Diagram[]\n      +createdAt: datetime\n    }\n\n    class Diagram {\n      +id: string\n      +type: string\n      +code: string\n      +revision: int\n    }\n\n    class ValidationReport {\n      +isValid: bool\n      +errors: string[]\n      +warnings: string[]\n    }\n\n    DiagramEngine o-- PluginRegistry : owns\n    PluginRegistry o-- DiagramPlugin : stores\n    DiagramPlugin <|.. FlowchartPlugin\n    DiagramPlugin <|.. SequencePlugin\n    Project *-- Diagram : contains\n    DiagramEngine --> Project : loads\n    DiagramEngine --> ValidationReport : returns\n    note for DiagramEngine \"Coordinates parse, validate and render pipeline\""
    },
